# --- Supabase（必須）---
# ダッシュボード → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# サーバー専用（Stripe Webhook で subscriptions を更新 / Cron で管理者 API を使う場合に必須）
# 絶対にクライアントや Git に載せないこと
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- サイト URL（メール内リンク・Stripe リダイレクト推奨）---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Checkout の success/cancel に使う（未設定時はリクエスト Host から推測）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe（課金を使う場合）---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# 任意: ダッシュボードの Price ID（未設定時はサーバーが price_data を生成）
# STRIPE_PRICE_LITE=price_xxx
# STRIPE_PRICE_STANDARD=price_xxx
# STRIPE_PRICE_PROFESSIONAL=price_xxx

# --- メール（Gmail 等・10ヶ月リマインド等で使用）---
EMAIL_USER=
EMAIL_PASSWORD=

# --- Vercel Cron / 手動トリガー用（/api/cron/data-cleanup）---
# Vercel では環境変数 CRON_SECRET を設定すると Authorization: Bearer が付与される
CRON_SECRET=
