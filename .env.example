# --- Supabase（必須）---
# ダッシュボード → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# 認証 Cookie 名の基底（Middleware / ブラウザで一致必須。未設定時はコード既定 sb-feety-auth-token）
NEXT_PUBLIC_SUPABASE_AUTH_STORAGE_KEY=sb-feety-auth-token

# サーバー専用（Stripe Webhook で subscriptions を更新 / Cron で管理者 API を使う場合に必須）
# 絶対にクライアントや Git に載せないこと
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- サイト URL（メール内リンク・Stripe リダイレクト推奨）---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Checkout の success/cancel に使う（未設定時はリクエスト Host から推測）
# Vercel 本番では必ず本番ドメインを設定（例: https://www.seo-oji.space）
NEXT_PUBLIC_APP_URL=http://localhost:3000
# HP（マーケ）のボタンが飛ぶ先。未設定時は https://www.seo-oji.space
# NEXT_PUBLIC_FEETY_APP_ORIGIN=https://www.seo-oji.space

# --- Stripe（課金を使う場合）---
# 本番運用: Stripe ダッシュボードで「本番データの表示」に切り替え、sk_live_... とライブ用 Webhook を設定
# 開発・検証: sk_test_... / テストモード Webhook
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# 本番ではライブ Price ID を推奨（未設定時はサーバーが price_data を生成・金額は lib/stripe/catalog.ts）
# 月額サブスク（各プラン）:
# STRIPE_PRICE_LITE_MONTHLY=price_xxx
# STRIPE_PRICE_STANDARD_MONTHLY=price_xxx
# STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_xxx
# 初回のみ請求のお手続き料（全プラン共通・ワンタイム Price）:
# STRIPE_PRICE_INITIAL_FEE=price_xxx
# 後方互換: STRIPE_PRICE_LITE 等があれば _MONTHLY 未設定時に月額として使用
# STRIPE_PRICE_LITE=price_xxx
#
# 本番チェックリスト（Stripe ライブ）:
# - STRIPE_SECRET_KEY は sk_live_...（本番ビルドで sk_test_ のままにしない）
# - Stripe → 開発者 → Webhook: エンドポイント https://（本番ドメイン）/api/stripe/webhook
#   イベント: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# - STRIPE_WEBHOOK_SECRET は上記エンドポイントの署名シークレット（whsec_...）
# - SUPABASE_SERVICE_ROLE_KEY を Vercel に設定（Webhook が subscriptions を upsert するために必須）
# - NEXT_PUBLIC_SITE_URL / NEXT_PUBLIC_APP_URL / NEXT_PUBLIC_FEETY_APP_ORIGIN を本番 URL で統一

# --- メール（Gmail 等・10ヶ月リマインド等で使用）---
EMAIL_USER=
EMAIL_PASSWORD=

# --- Vercel Cron / 手動トリガー用（/api/cron/data-cleanup）---
# Vercel では環境変数 CRON_SECRET を設定すると Authorization: Bearer が付与される
CRON_SECRET=
